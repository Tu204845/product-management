extends ../../layouts/default.pug
include ../../mixins/box-head.pug

block main
  .container.my-3
    .row
      .col-12
        +box-head("Chat")

    .row
      .col-12
        .chat(my-id=user.id)
          .inner-body
            each chat in chats
              div(class=(chat.user_id.toString() === user.id.toString() ? "inner-outgoing" : "inner-incoming"))
                if(chat.user_id.toString() !== user.id.toString())
                  .inner-name #{chat.infoUser.fullName}
                .inner-content #{chat.content}

            div(class="inner-list-typing")

          .inner-foot
            form.inner-form(
                class="inner-form"
                action="")
              input(
                type="text"
                placeholder="Nhập nội dung..."
                name="content"
              )
              button.button-icon(type="button")
                i.fa-regular.fa-face-smile
              button
                i.fa-solid.fa-paper-plane

  div(class="tooltip" role="tooltip")
    emoji-picker
  